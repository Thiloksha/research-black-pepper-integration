generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum DetectionStatus {
  SUCCESS
  REJECTED
  FAILED
}

model DiseaseDetection {
  id               String   @id @default(uuid())

  imageUrl         String?
  imageName        String?
  imageMimeType    String?
  imageSizeBytes   Int?

  predictedDisease String?
  confidence       Decimal? @db.Decimal(5, 2)

  description      String?
  treatment        String?

  lowConfidence    Boolean  @default(false)
  pepperScore      Decimal? @db.Decimal(5, 2)

  rejectReason     String?
  rawResponse      Json?

  createdAt        DateTime @default(now())

  probabilities    DetectionProbability[]

  @@index([predictedDisease])
  @@index([createdAt])
  @@map("disease_detections")
}

model DetectionProbability {
  id           String   @id @default(uuid())
  detectionId  String
  diseaseName  String
  probability  Decimal  @db.Decimal(5, 2)

  detection    DiseaseDetection @relation(fields: [detectionId], references: [id], onDelete: Cascade)

  @@index([detectionId])
  @@map("detection_probabilities")
}

model VarietyDetection {
  id                  String   @id @default(uuid())

  imageName           String?
  imageMimeType       String?
  imageSizeBytes      Int?

  stageALabel         String?
  stageAConfidence    Decimal? @db.Decimal(5, 2)

  predictedVariety    String?
  confidence          Decimal? @db.Decimal(5, 2)

  message             String?
  accepted            Boolean  @default(true)
  lowConfidence       Boolean  @default(false)

  rawResponse         Json?
  createdAt           DateTime @default(now())

  probabilities       VarietyProbability[]

  @@index([predictedVariety])
  @@index([createdAt])
  @@map("variety_detections")
}

model VarietyProbability {
  id           String   @id @default(uuid())
  detectionId  String
  varietyName  String
  probability  Decimal  @db.Decimal(5, 2)

  detection    VarietyDetection @relation(fields: [detectionId], references: [id], onDelete: Cascade)

  @@index([detectionId])
  @@map("variety_probabilities")
}